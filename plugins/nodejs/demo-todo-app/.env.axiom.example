# Axiom.co Configuration for Demo Todo App
#
# Copy this file to .env and fill in your values:
#   cp .env.axiom.example .env
#
# Then start with Axiom configuration:
#   BSB_ENV=axiom bsb start

# ==========================================================================
# Axiom Required Configuration
# ==========================================================================

# Your Axiom API token (get from https://axiom.co)
# Create with: axiom token create bsb-demo --scopes ingest
AXIOM_TOKEN=xaat-your-token-here

# Axiom dataset name (create with: axiom dataset create bsb-demo)
AXIOM_DATASET=bsb-demo

# ==========================================================================
# Axiom Optional Configuration
# ==========================================================================

# Organization ID (for Axiom Cloud - find in Settings > Organization)
# AXIOM_ORG_ID=your-org-id

# Custom Axiom URL (for self-hosted Axiom)
# AXIOM_URL=https://axiom.mycompany.com

# ==========================================================================
# Application Configuration
# ==========================================================================

# Application version (for tracking deployments)
APP_VERSION=1.0.0

# Environment name (dev, staging, production)
ENVIRONMENT=development

# ==========================================================================
# Resource Attributes (added to all telemetry)
# ==========================================================================

# Cloud region (e.g., us-east-1, eu-west-1)
# AWS_REGION=us-east-1

# Datacenter identifier
# DATACENTER=dc1

# Host machine name
# HOSTNAME=demo-server-01

# Deployment identifier (e.g., git commit hash, CI build number)
# DEPLOYMENT_ID=abc123

# ==========================================================================
# Quick Start
# ==========================================================================
#
# 1. Sign up for Axiom: https://axiom.co
# 2. Create dataset:
#    axiom dataset create bsb-demo
# 3. Create API token:
#    axiom token create bsb-demo --scopes ingest
# 4. Copy this file:
#    cp .env.axiom.example .env
# 5. Update AXIOM_TOKEN and AXIOM_DATASET above
# 6. Start demo app:
#    BSB_ENV=axiom bsb start
# 7. Generate activity:
#    - Open http://localhost:3000
#    - Create/update/delete todos
# 8. View in Axiom:
#    - Go to https://axiom.co
#    - Open your dataset
#    - Query logs, metrics, and traces
#
# ==========================================================================
# Example Queries in Axiom
# ==========================================================================
#
# All logs:
#   ['bsb-demo'] | where service == "demo-todo-app"
#
# Errors only:
#   ['bsb-demo'] | where level == "error"
#
# Todo creation events:
#   ['bsb-demo'] | where message contains "created"
#
