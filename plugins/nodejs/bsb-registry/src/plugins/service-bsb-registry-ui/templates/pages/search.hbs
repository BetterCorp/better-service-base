<h1>Search Results</h1>

{{> search-form}}

{{#if searchQuery}}
  <div style="margin: 1.5rem 0; color: #bbb;">
    {{#if plugins}}
      Found <strong style="color: #FB8C00;">{{pagination.total}}</strong> plugin(s) matching "<strong>{{searchQuery}}</strong>"
    {{else}}
      No results found for "<strong>{{searchQuery}}</strong>"
    {{/if}}
  </div>
{{/if}}

{{#if plugins}}
  <div class="grid">
    {{#each plugins}}
      {{> plugin-card}}
    {{/each}}
  </div>

  {{#if pagination}}
    {{> pagination}}
  {{/if}}
{{else}}
  {{#if searchQuery}}
    <div style="text-align: center; margin: 3rem 0;">
      <p style="color: #888; font-size: 1.125rem;">No plugins found matching "{{searchQuery}}"</p>
      <p style="color: #666; margin-top: 1rem;">Try different keywords or browse all plugins.</p>
      <a href="/plugins" class="btn" style="margin-top: 1rem;">Browse All Plugins</a>
    </div>
  {{/if}}
{{/if}}
