{
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "types": [
      "node"
    ],
    "noImplicitAny": true,
    "removeComments": false,
    "preserveConstEnums": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "sourceMap": true,
    "outDir": "lib",
    "rootDir": "src",
    "strict": true,
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "linterOptions": {
    "exclude": [
      "src/plugins/-*/**/*.*",
      "src/plugins/*-test/**/*.*"
    ]
  },
  "compileOnSave": true,
  "include": [
    "src",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules/**",
    "src/plugins/*-test/**/*.*",
    "src/plugins/-*/**/*.*",
    "src/tests/**",
    "src/tests.ts"
  ]
}
