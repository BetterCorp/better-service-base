{
  "name": "@bettercorp/service-base",
  "license": "(AGPL-3.0-only OR Commercial)",
  "repository": {
    "url": "git+https://github.com/BetterCorp/better-service-base.git"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "generate-docs": "typedoc --json ./docs.json --tsconfig ./tsconfig-release.json  --cacheBust src/index.ts",
    "generate-docs2": "typedoc --out ./odocs --tsconfig ./tsconfig-release.json --cacheBust src/index.ts",
    "dev": "nodemon --config ./nodemon.json",
    "start": "node lib/cli.js",
    "build": "rm -rfv ./lib && tsc && npm run testDev",
    "build-release": "rm -rfv ./lib && tsc",
    "build-release-old": "rm -rfv ./lib && tsc --p ./tsconfig-release.json && npm run build-release-tsconfig",
    "build-release-tsconfig": "rm -fv ./development/tsconfig.json && cp ./tsconfig.json ./development/tsconfig.json",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "test": "node ./node_modules/nyc/bin/nyc.js --reporter json --reporter lcov ./node_modules/mocha/bin/mocha.js -r ts-node/register 'src/tests/**/*.ts' --reporter json --reporter-options output=junit.json",
    "testDev": "NODE_OPTIONS=\"--loader ts-node/esm\" ts-node ./node_modules/nyc/bin/nyc.js ./node_modules/mocha/bin/mocha.js -r ts-node/register 'src/tests/**/*.ts'"
  },
  "bin": {
    "bsb": "lib/cli.js"
  },
  "files": [
    "lib/**/*",
    "development/**/*",
    "README.md",
    "LICENSE"
  ],
  "main": "lib/index.js",
  "version": "9.0.4-beta",
  "devDependencies": {
    "@types/assert": "^1.5.10",
    "@types/chai": "^4.3.11",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.12",
    "@types/uuid": "^10.0.0",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "chai": "^4.3.10",
    "eslint": "^8.56.0",
    "install": "^0.13.0",
    "mocha": "^10.2.0",
    "npm": "^10.2.5",
    "nyc": "^15.1.0",
    "ts-morph": "^21.0.1",
    "ts-node": "^10.9.2",
    "typedoc": "^0.26.5",
    "typescript": "^5.5.4",
    "yargs": "^17.7.2"
  },
  "dependencies": {
    "@bettercorp/tools": "^3.7.0",
    "uuid": "^11.0.5",
    "yaml": "^2.7.0",
    "yargs": "^17.7.2",
    "zod": "^3.24.1"
  }
}
