{
  "name": "@bettercorp/service-base",
  "license": "(AGPL-3.0-only OR Commercial)",
  "repository": {
    "url": "git+https://github.com/BetterCorp/better-service-base.git"
  },
  "engines": {
    "npm": ">=11.0.0",
    "node": ">=23.0.0"
  },
  "scripts": {
    "generate-docs": "typedoc --json ./docs.json --tsconfig ./tsconfig-release.json  --cacheBust src/index.ts",
    "docs": "mkdir -p ../docs/dist/languages/nodejs/types && rimraf ../docs/dist/languages/nodejs/types/* && typedoc --out ../docs/dist/languages/nodejs/types --tsconfig ./tsconfig-release.json --cacheBust src/index.ts",
    "dev": "ts-node src/dev.ts",
    "start": "node lib/cli.js",
    "tsc": "echo 'cleaning...' && rm -rf ./lib && echo 'building...' && tsc && echo 'done'",
    "build": "rimraf ./lib && tsc && npm run testDev && npm run generate-docs",
    "build-release": "rimraf ./lib && tsc --p ./tsconfig-release.json",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "test": "cross-env TS_NODE_PROJECT=tsconfig.test.json NODE_OPTIONS= nyc --reporter json --reporter lcov mocha --reporter json --reporter-options output=junit.json",
    "testDev": "cross-env TS_NODE_PROJECT=tsconfig.test.json NODE_OPTIONS= nyc mocha",
    "test:watch": "cross-env TS_NODE_PROJECT=tsconfig.test.json NODE_OPTIONS= mocha --watch --watch-files src"
  },
  "bin": {
    "bsb": "lib/cli.js"
  },
  "files": [
    "lib/*.*",
    "lib/base/**/*",
    "lib/interfaces/**/*",
    "lib/serviceBase/**/*",
    "lib/plugins/config-*/**/*",
    "lib/plugins/events-*/**/*",
    "lib/plugins/metrics-*/**/*",
    "lib/plugins/logging-*/**/*",
    "README.md",
    "LICENSE"
  ],
  "main": "lib/index.js",
  "version": "9.5.8-next",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/assert": "^1.5.10",
    "@types/chai": "^4.3.11",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.1.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "benchmarkify": "^4.0.0",
    "chai": "^4.3.10",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "nyc": "^17.1.0",
    "rimraf": "^6.1.2",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.16",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "uuid": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
