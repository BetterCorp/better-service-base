  "scripts": {
    "dev": "vite --host=0.0.0.0",
    "build": "vite build && npm run build-types:nodejs",
    "build-types:nodejs": "npm run build-types:nodejs:clean && npm run build-types:nodejs:generate",
    "build-types:nodejs:clean": "rimraf dist/languages/nodejs/types",
    "build-types:nodejs:generate": "typedoc --out dist/languages/nodejs/types --tsconfig ../nodejs/tsconfig-release.json --cacheBust ../nodejs/src/index.ts",
    "preview": "node preview-server.js"
  },
