    "markdown-it-prism": "^2.3.0",
    "polka": "^0.5.2",
    "rimraf": "^6.0.1",
    "sirv-cli": "^3.0.1",
    "typedoc": "^0.28.0",
    "vite": "^5.0.0",
    "zod": "^4.3.6"
  }
